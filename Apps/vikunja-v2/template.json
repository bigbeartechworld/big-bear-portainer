        {"name": "VIKUNJA_DATABASE_USER", "label": "VIKUNJA_DATABASE_USER", "description": "Database user", "default": "vikunja"},
        {"name": "VIKUNJA_DATABASE_DATABASE", "label": "VIKUNJA_DATABASE_DATABASE", "description": "Database name", "default": "vikunja"},
